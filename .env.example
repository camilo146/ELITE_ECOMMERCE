# ──────────────────────────────────────────────────────────────────────────────
#  ÉLITE — Plantilla de variables de entorno
#  Este archivo SÍ se puede versionar (sin valores reales).
#  Para usar: cp .env.example .env  y rellena los valores.
# ──────────────────────────────────────────────────────────────────────────────

# ── MercadoPago ───────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=tu_webhook_secret_del_panel_mp

# ── JWT (solo producción — dev usa secret interno automáticamente) ────────────
# Generar: openssl rand -base64 64
JWT_SECRET=

# ── Base de datos PostgreSQL (solo producción) ────────────────────────────────
DB_NAME=elite_db
DB_USER=elite_user
DB_PASSWORD=

# ── Redis (solo producción) ───────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Email — Resend (https://resend.com) ───────────────────────────────────────
# API Key de Resend (gratis hasta 3000 emails/mes)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Dirección remitente — usa onboarding@resend.dev sin dominio propio
# Con dominio propio verificado: noreply@tudominio.com
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=ÉLITE

# ── URLs de producción ────────────────────────────────────────────────────────
FRONTEND_URL=https://tudominio.com
BACKEND_URL=https://tudominio.com

# ── Sentry (tracking de errores) ──────────────────────────────────────────────
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxxx
