# ──────────────────────────────────────────────────────────────────────────────
#  ÉLITE — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Secretos / entorno ────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Documentación interna (no va al repo) ────────────────────────────────────
*.md
*.MD

# ── Archivos temporales / comentados ─────────────────────────────────────────
BACKEND_COMENTADO.java
FRONTEND_COMENTADO.js
*.bat
railway.json

# ── Dependencias ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
frontend/dist/
backend-java/target/
dist/
build/
.vite/
*.class
*.jar
!backend-java/src/
*.war

# ── Base de datos ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── SSL / Certificados ────────────────────────────────────────────────────────
ssl/certs/
ssl/dhparam.pem
ssl/*.pem
ssl/*.key
ssl/*.crt

# ── Docker override local ─────────────────────────────────────────────────────
docker-compose.override.yml

# ── Uploads de usuarios ───────────────────────────────────────────────────────
uploads/
backend-java/uploads/
**/uploads/*
!**/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-error.log*

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Sistema operativo ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Testing / cobertura ───────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
